APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="Rasa Group"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

RAJAONGKIR_KEY=
RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id/api/v1

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# QID / QAD API — order distributor & POS (aktif otomatis jika kredensial terisi)
QIDAPI_BASE_URL=
QIDAPI_USERNAME=
QIDAPI_PASSWORD=
QIDAPI_APPS_ID=


JUBELIO_EMAIL=
JUBELIO_PASSWORD=
JUBELIO_SALES_ORDER_ENABLED=true
JUBELIO_STATUS_POLL_ENABLED=true
JUBELIO_STATUS_POLL_INTERVAL=5
JUBELIO_STATUS_POLL_BATCH_SIZE=50
JUBELIO_PRODUCT_CONTENT_SYNC_ENABLED=true
JUBELIO_PRODUCT_CONTENT_REPLACE_GALLERY=true

# Debug pencocokan SKU Jubelio vs QAD saat sync (log: storage/logs/master-sync.log & product-match-debug.json)
MASTER_SYNC_PRODUCT_MATCH_DEBUG=true

# Belanja web: abaikan validasi stok, hub otomatis terdekat alamat
SHOP_ASSUME_STOCK_READY=true
SHOP_AUTO_HUB_BY_ADDRESS=true
SHOP_SHOW_STOCK=false
# Opsional: fallback jika lookup customer/lokasi gagal
# JUBELIO_DEFAULT_CONTACT_ID=
# JUBELIO_DEFAULT_LOCATION_ID=
# Uji artisan jubelio:test-so (minimal tanpa order)
# JUBELIO_TEST_CONTACT_ID=
# JUBELIO_TEST_LOCATION_ID=
# JUBELIO_TEST_ITEM_CODE=

# Payment Gateway
ACTIVE_PAYMENT_GATEWAY=xendit


BYPASS_WA_VERIFICATION=true
